<div
  id="lightbox"
  class="fixed inset-0 z-[100] hidden cursor-zoom-out touch-none items-center justify-center overscroll-none bg-black/90 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="图片预览"
  hidden
>
  <img
    id="lightbox-image"
    class="max-h-[92vh] max-w-[min(100%,96vw)] object-contain shadow-2xl"
    alt=""
  />
</div>

<script is:inline>
  (function () {
    const LIGHTBOX_SELECTOR = "#main-content .app-prose img";

    /** @param {string} srcset @param {string} fallback */
    function getLargestSrcFromSrcset(srcset, fallback) {
      let bestSrc = fallback;
      let bestScore = -1;

      for (const part of srcset.split(",")) {
        const [url, descriptor] = part.trim().split(/\s+/);
        if (!url) continue;

        let score = 1;
        if (descriptor?.endsWith("w")) {
          score = parseInt(descriptor, 10) || 0;
        } else if (descriptor?.endsWith("x")) {
          score = (parseFloat(descriptor) || 1) * 10000;
        }

        if (score >= bestScore) {
          bestScore = score;
          bestSrc = url;
        }
      }

      return bestSrc;
    }

    /** @param {HTMLImageElement} img */
    function getFullImageSrc(img) {
      const picture = img.closest("picture");
      const srcsets = [];

      if (picture) {
        picture.querySelectorAll("source[srcset]").forEach(source => {
          const srcset = source.getAttribute("srcset");
          if (srcset) srcsets.push(srcset);
        });
      }

      if (img.srcset) srcsets.push(img.srcset);

      if (srcsets.length > 0) {
        let bestSrc = img.currentSrc || img.src;
        let bestScore = -1;

        for (const srcset of srcsets) {
          for (const part of srcset.split(",")) {
            const [url, descriptor] = part.trim().split(/\s+/);
            if (!url) continue;

            let score = 1;
            if (descriptor?.endsWith("w")) {
              score = parseInt(descriptor, 10) || 0;
            } else if (descriptor?.endsWith("x")) {
              score = (parseFloat(descriptor) || 1) * 10000;
            }

            if (score >= bestScore) {
              bestScore = score;
              bestSrc = url;
            }
          }
        }

        return bestSrc;
      }

      return img.currentSrc || img.src;
    }

    /** @type {boolean} */
    let isOpen = false;
    /** @type {number} */
    let scrollY = 0;

    function lockScroll() {
      scrollY = window.scrollY;
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
      document.body.style.position = "fixed";
      document.body.style.top = `-${scrollY}px`;
      document.body.style.left = "0";
      document.body.style.right = "0";
      document.body.style.width = "100%";
    }

    function unlockScroll() {
      const y = scrollY;
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
      document.body.style.position = "";
      document.body.style.top = "";
      document.body.style.left = "";
      document.body.style.right = "";
      document.body.style.width = "";

      // Override scroll-smooth on html to avoid animating from top on close
      const root = document.documentElement;
      const previousScrollBehavior = root.style.scrollBehavior;
      root.style.scrollBehavior = "auto";
      window.scrollTo(0, y);
      root.style.scrollBehavior = previousScrollBehavior;
    }

    function getElements() {
      return {
        lightbox: document.getElementById("lightbox"),
        lightboxImage: document.getElementById("lightbox-image"),
      };
    }

    function openLightbox(/** @type {HTMLImageElement} */ img) {
      const { lightbox, lightboxImage } = getElements();
      if (!lightbox || !lightboxImage) return;

      lightboxImage.src = getFullImageSrc(img);
      lightboxImage.alt = img.alt || "放大图片";
      lightbox.removeAttribute("hidden");
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      lockScroll();
      isOpen = true;
    }

    function closeLightbox() {
      const { lightbox, lightboxImage } = getElements();
      if (!lightbox || !lightboxImage || !isOpen) return;

      lightbox.setAttribute("hidden", "");
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightboxImage.removeAttribute("src");
      unlockScroll();
      isOpen = false;
    }

    function onDocumentClick(/** @type {MouseEvent} */ event) {
      const { lightbox } = getElements();
      if (!lightbox) return;

      if (isOpen) {
        event.preventDefault();
        event.stopPropagation();
        closeLightbox();
        return;
      }

      const target = event.target;
      if (!(target instanceof Element)) return;

      const img = target.closest(LIGHTBOX_SELECTOR);
      if (!(img instanceof HTMLImageElement)) return;

      event.preventDefault();
      event.stopPropagation();
      openLightbox(img);
    }

    function onKeydown(/** @type {KeyboardEvent} */ event) {
      if (event.key === "Escape") closeLightbox();
    }

    function onTouchMove(/** @type {TouchEvent} */ event) {
      if (!isOpen) return;
      event.preventDefault();
    }

    function init() {
      if (window.__lightboxInitialized) return;
      window.__lightboxInitialized = true;

      document.addEventListener("click", onDocumentClick);
      document.addEventListener("keydown", onKeydown);
      document.addEventListener("touchmove", onTouchMove, { passive: false });
      document.addEventListener("astro:before-swap", closeLightbox);
    }

    init();
  })();
</script>
